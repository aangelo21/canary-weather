<script>
    // View Switching Logic
    function switchView(viewName) {
        const poisSection = document.getElementById('pois-section');
        const usersSection = document.getElementById('users-section');
        const btnPois = document.getElementById('btn-pois');
        const btnUsers = document.getElementById('btn-users');

        if (viewName === 'pois') {
            poisSection.classList.remove('hidden');
            usersSection.classList.add('hidden');

            btnPois.classList.remove('text-gray-600', 'hover:text-gray-900', 'bg-transparent');
            btnPois.classList.add('bg-brand-primary', 'text-white');

            btnUsers.classList.add('text-gray-600', 'hover:text-gray-900', 'bg-transparent');
            btnUsers.classList.remove('bg-brand-primary', 'text-white');

            localStorage.setItem('adminView', 'pois');
        } else {
            poisSection.classList.add('hidden');
            usersSection.classList.remove('hidden');

            btnUsers.classList.remove('text-gray-600', 'hover:text-gray-900', 'bg-transparent');
            btnUsers.classList.add('bg-brand-primary', 'text-white');

            btnPois.classList.add('text-gray-600', 'hover:text-gray-900', 'bg-transparent');
            btnPois.classList.remove('bg-brand-primary', 'text-white');

            localStorage.setItem('adminView', 'users');
        }
    }

    // Initialize Charts
    document.addEventListener('DOMContentLoaded', function() {
        // Restore view from localStorage
        const savedView = localStorage.getItem('adminView') || 'pois';
        switchView(savedView);

        const stats = <%- JSON.stringify(stats || {}) %>;

        if (stats.poiByCategory) {
            const ctx = document.getElementById('poiCategoryChart');
            if (Chart.getChart(ctx)) {
                Chart.getChart(ctx).destroy();
            }
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: stats.poiByCategory.map(item => item.type),
                    datasets: [{
                        label: 'POIs por Categoría',
                        data: stats.poiByCategory.map(item => item.count),
                        backgroundColor: '#8884d8'
                    }]
                }
            });
        }

        if (stats.usersPerLocation) {
            const ctx = document.getElementById('userLocationChart');
            if (Chart.getChart(ctx)) {
                Chart.getChart(ctx).destroy();
            }
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: stats.usersPerLocation.map(item => item.Location ? item.Location.name : 'Desconocido'),
                    datasets: [{
                        label: 'Usuarios por Localización',
                        data: stats.usersPerLocation.map(item => item.count),
                        backgroundColor: '#82ca9d'
                    }]
                }
            });
        }

        if (stats.usersPerDay) {
            const ctx = document.getElementById('userGrowthChart');
            if (Chart.getChart(ctx)) {
                Chart.getChart(ctx).destroy();
            }
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: stats.usersPerDay.map(item => item.date),
                    datasets: [{
                        label: 'Nuevos Usuarios',
                        data: stats.usersPerDay.map(item => item.count),
                        borderColor: '#8884d8',
                        tension: 0.1
                    }]
                }
            });
        }

        if (stats.poisPerDay) {
            const ctx = document.getElementById('poiGrowthChart');
            if (Chart.getChart(ctx)) {
                Chart.getChart(ctx).destroy();
            }
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: stats.poisPerDay.map(item => item.date),
                    datasets: [{
                        label: 'Nuevos POIs',
                        data: stats.poisPerDay.map(item => item.count),
                        borderColor: '#82ca9d',
                        tension: 0.1
                    }]
                }
            });
        }
    });

    // POI Modal Functions
    function openCreateModal() {
        document.getElementById('createModal').classList.remove('hidden');
    }

    function closeCreateModal() {
        document.getElementById('createModal').classList.add('hidden');
    }

    function openEditModal(id, name, lat, lng, type, description) {
        document.getElementById('editName').value = name;
        document.getElementById('editLatitude').value = lat;
        document.getElementById('editLongitude').value = lng;
        document.getElementById('editType').value = type;
        document.getElementById('editDescription').value = description || '';
        document.getElementById('editForm').action = `/admin/poi/${id}/update`;
        document.getElementById('editModal').classList.remove('hidden');
    }

    function closeEditModal() {
        document.getElementById('editModal').classList.add('hidden');
    }

    function openDeleteModal(id) {
        document.getElementById('deleteForm').action = `/admin/poi/${id}/delete`;
        document.getElementById('deleteModal').classList.remove('hidden');
    }

    function closeDeleteModal() {
        document.getElementById('deleteModal').classList.add('hidden');
    }

    // User Modal Functions
    function openCreateUserModal() {
        document.getElementById('createUserModal').classList.remove('hidden');
    }

    function closeCreateUserModal() {
        document.getElementById('createUserModal').classList.add('hidden');
    }

    function openEditUserModal(id, username, email, isAdmin) {
        document.getElementById('editUsername').value = username;
        document.getElementById('editEmail').value = email;
        document.getElementById('editIsAdmin').checked = (isAdmin === 'true');
        document.getElementById('editUserForm').action = `/admin/users/${id}/update`;
        document.getElementById('editUserModal').classList.remove('hidden');
    }

    function closeEditUserModal() {
        document.getElementById('editUserModal').classList.add('hidden');
    }

    function openDeleteUserModal(id) {
        document.getElementById('deleteUserForm').action = `/admin/users/${id}/delete`;
        document.getElementById('deleteUserModal').classList.remove('hidden');
    }

    function closeDeleteUserModal() {
        document.getElementById('deleteUserModal').classList.add('hidden');
    }
</script>
