<div id="pois-section" class="mt-6">
    <div class="flex justify-between items-center mb-6">
        <h2 class="text-2xl font-bold text-gray-800">Puntos de Interés</h2>
        <button onclick="openCreateModal()" class="bg-green-600 hover:bg-green-700 text-white font-medium py-2 px-4 rounded-lg transition-colors shadow-sm">
            + Crear POI Global
        </button>
    </div>

    <div class="bg-white p-4 rounded-xl shadow-sm border border-gray-100 mb-6">
        <form action="/admin" method="GET" class="flex flex-wrap gap-4 items-end">
            <div class="flex-1 min-w-[200px]">
                <label for="search" class="block text-sm font-medium text-gray-700 mb-1">Buscar por Nombre</label>
                <input type="text" name="search" id="search" value="<%= filters.search || '' %>" placeholder="Buscar POIs..." class="w-full rounded-lg border-gray-300 shadow-sm focus:border-brand-primary focus:ring-brand-primary">
            </div>
            <div class="w-48">
                <label for="type" class="block text-sm font-medium text-gray-700 mb-1">Tipo</label>
                <select name="type" id="type" class="w-full rounded-lg border-gray-300 shadow-sm focus:border-brand-primary focus:ring-brand-primary">
                    <option value="">Todos</option>
                    <option value="global" <%= filters.type === 'global' ? 'selected' : '' %>>Global</option>
                    <option value="local" <%= filters.type === 'local' ? 'selected' : '' %>>Local (Municipio)</option>
                    <option value="personal" <%= filters.type === 'personal' ? 'selected' : '' %>>Personal</option>
                </select>
            </div>
            <button type="submit" class="bg-brand-primary hover:bg-blue-700 text-white font-medium py-2 px-6 rounded-lg transition-colors">
                Filtrar
            </button>
            <% if (filters.search || filters.type) { %>
                <a href="/admin" class="text-gray-600 hover:text-gray-800 font-medium py-2 px-4">Limpiar</a>
            <% } %>
        </form>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Nombre</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tipo</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Creado Por</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Coordenadas</th>
                        <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Acciones</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    <% if (pois && pois.length > 0) { %>
                        <% pois.forEach(poi => { %>
                            <tr>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="text-sm font-medium text-gray-900"><%= poi.name %></div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <% if (poi.type === 'global') { %>
                                        <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">Global</span>
                                    <% } else if (poi.type === 'local') { %>
                                        <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 text-blue-800">Local</span>
                                    <% } else { %>
                                        <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-purple-100 text-purple-800">Personal</span>
                                    <% } %>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                    <% if (poi.creator) { %>
                                        <%= poi.creator.email %>
                                    <% } else { %>
                                        <span class="text-gray-400">-</span>
                                    <% } %>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                    <%= poi.latitude %>, <%= poi.longitude %>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                    <button onclick='openEditModal(<%- JSON.stringify(poi.id) %>, <%- JSON.stringify(poi.name) %>, <%- JSON.stringify(poi.latitude) %>, <%- JSON.stringify(poi.longitude) %>, <%- JSON.stringify(poi.type) %>, <%- JSON.stringify(poi.description || "") %>)' class="text-indigo-600 hover:text-indigo-900 mr-4">Editar</button>
                                    <button onclick="openDeleteModal('<%= poi.id %>')" class="text-red-600 hover:text-red-900">Eliminar</button>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" class="px-6 py-12 text-center text-gray-500">
                                No se encontraron puntos de interés.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>
