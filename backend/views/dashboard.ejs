<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - Canary Weather</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 20px; }
        h1 { color: #333; }
        .stats { display: flex; gap: 20px; margin-top: 20px; }
        .card { border: 1px solid #ddd; padding: 20px; border-radius: 8px; min-width: 200px; }
        .card h2 { margin-top: 0; }
    </style>
</head>
<body>
    <h1>Admin Dashboard</h1>
    <p>Welcome to the Canary Weather Admin Dashboard.</p>
    
    <div class="stats">
        <div class="card">
            <h2>Users</h2>
            <p>Total Users: <%= usersCount %></p>
        </div>
        <div class="card">
            <h2>POIs</h2>
            <p>Total POIs: <%= poisCount %></p>
        </div>
         <div class="card">
            <h2>Alerts</h2>
            <p>Active Alerts: <%= alertsCount %></p>
        </div>
    </div>
</body>
</html>
