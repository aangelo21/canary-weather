<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - Canary Weather</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            primary: '#0768a9',
                        }
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-gray-50 p-8 font-sans">
    <div class="max-w-6xl mx-auto">
        <div class="flex justify-between items-center mb-8">
            <h1 class="text-3xl font-bold text-gray-800">Admin Dashboard</h1>
            <a href="<%= frontendUrl %>" class="bg-brand-primary hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg inline-flex items-center transition-colors shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
                </svg>
                Volver al inicio
            </a>
        </div>

        <p class="text-gray-600 mb-8">Welcome to the Canary Weather Admin Dashboard.</p>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
                <h2 class="text-xl font-semibold text-gray-800 mb-2">Users</h2>
                <p class="text-3xl font-bold text-brand-primary"><%= usersCount %></p>
                <p class="text-sm text-gray-500 mt-1">Total Users</p>
            </div>
            <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
                <h2 class="text-xl font-semibold text-gray-800 mb-2">POIs</h2>
                <p class="text-3xl font-bold text-brand-primary"><%= poisCount %></p>
                <p class="text-sm text-gray-500 mt-1">Total POIs</p>
            </div>
             <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
                <h2 class="text-xl font-semibold text-gray-800 mb-2">Alerts</h2>
                <p class="text-3xl font-bold text-brand-primary"><%= alertsCount %></p>
                <p class="text-sm text-gray-500 mt-1">Active Alerts</p>
            </div>
        </div>

        <div class="mt-12">
            <div class="flex justify-between items-center mb-6">
                <h2 class="text-2xl font-bold text-gray-800">Points of Interest</h2>
            </div>

            <div class="bg-white p-4 rounded-xl shadow-sm border border-gray-100 mb-6">
                <form action="/admin" method="GET" class="flex flex-wrap gap-4 items-end">
                    <input type="hidden" name="token" value="<%= token %>">
                    <div class="flex-1 min-w-[200px]">
                        <label for="search" class="block text-sm font-medium text-gray-700 mb-1">Search by Name</label>
                        <input type="text" name="search" id="search" value="<%= filters.search || '' %>" placeholder="Search POIs..." class="w-full rounded-lg border-gray-300 shadow-sm focus:border-brand-primary focus:ring-brand-primary">
                    </div>
                    <div class="w-48">
                        <label for="isGlobal" class="block text-sm font-medium text-gray-700 mb-1">Type</label>
                        <select name="isGlobal" id="isGlobal" class="w-full rounded-lg border-gray-300 shadow-sm focus:border-brand-primary focus:ring-brand-primary">
                            <option value="">All Types</option>
                            <option value="true" <%= filters.isGlobal === 'true' ? 'selected' : '' %>>Global</option>
                            <option value="false" <%= filters.isGlobal === 'false' ? 'selected' : '' %>>User Created</option>
                        </select>
                    </div>
                    <button type="submit" class="bg-brand-primary hover:bg-blue-700 text-white font-medium py-2 px-6 rounded-lg transition-colors">
                        Filter
                    </button>
                    <% if (filters.search || filters.isGlobal) { %>
                        <a href="/admin?token=<%= token %>" class="text-gray-600 hover:text-gray-800 font-medium py-2 px-4">Clear</a>
                    <% } %>
                </form>
            </div>

            <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
                                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
                                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Created By</th>
                                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Coordinates</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            <% if (pois && pois.length > 0) { %>
                                <% pois.forEach(poi => { %>
                                    <tr>
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            <div class="text-sm font-medium text-gray-900"><%= poi.name %></div>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            <% if (poi.is_global) { %>
                                                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">Global</span>
                                            <% } else { %>
                                                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 text-blue-800">User Created</span>
                                            <% } %>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                            <% if (poi.Users && poi.Users.length > 0) { %>
                                                <% poi.Users.forEach(user => { %>
                                                    <div class="mb-1"><%= user.email %></div>
                                                <% }) %>
                                            <% } else { %>
                                                <span class="text-gray-400">-</span>
                                            <% } %>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                            <%= poi.latitude %>, <%= poi.longitude %>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="4" class="px-6 py-12 text-center text-gray-500">
                                        No points of interest found matching your criteria.
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
