<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - Canary Weather</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            primary: '#0768a9',
                        }
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-gray-50 p-8 font-sans">
    <div class="max-w-6xl mx-auto">
        <div class="flex justify-between items-center mb-8">
            <h1 class="text-3xl font-bold text-gray-800">Admin Dashboard</h1>
            <a href="<%= frontendUrl %>" class="bg-brand-primary hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg inline-flex items-center transition-colors shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
                </svg>
                Volver al inicio
            </a>
        </div>

        <p class="text-gray-600 mb-8">Welcome to the Canary Weather Admin Dashboard.</p>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
                <h2 class="text-xl font-semibold text-gray-800 mb-2">Users</h2>
                <p class="text-3xl font-bold text-brand-primary"><%= usersCount %></p>
                <p class="text-sm text-gray-500 mt-1">Total Users</p>
            </div>
            <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
                <h2 class="text-xl font-semibold text-gray-800 mb-2">POIs</h2>
                <p class="text-3xl font-bold text-brand-primary"><%= poisCount %></p>
                <p class="text-sm text-gray-500 mt-1">Total POIs</p>
            </div>
             <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
                <h2 class="text-xl font-semibold text-gray-800 mb-2">Alerts</h2>
                <p class="text-3xl font-bold text-brand-primary"><%= alertsCount %></p>
                <p class="text-sm text-gray-500 mt-1">Active Alerts</p>
            </div>
        </div>
    </div>
</body>
</html>
