<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panel de Administración - Canary Weather</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            primary: '#0768a9',
                        }
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-gray-50 p-8 font-sans">
    <div class="max-w-6xl mx-auto">
        <%- include('./components/dashboard/header') %>

        <p class="text-gray-600 mb-8">Bienvenido al Panel de Administración de Canary Weather.</p>

        <%- include('./components/dashboard/stats') %>

        <%- include('./components/dashboard/charts') %>

        <%- include('./components/dashboard/viewSwitcher') %>

        <%- include('./components/dashboard/poiSection') %>

        <%- include('./components/dashboard/usersSection') %>
    </div>

    <%- include('./components/dashboard/poiModals') %>

    <%- include('./components/dashboard/userModals') %>

    <%- include('./components/dashboard/scripts') %>
</body>
</html>
